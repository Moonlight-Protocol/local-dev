# Target environment: "local" (default), "testnet", or "mainnet"
# Local runs against the local-dev stack (down.sh + up.sh).
TARGET=local

# Freighter extension path (unpacked directory)
# Download from https://github.com/nickhealx/freighter/releases
# Unpack the .zip and point this to the extracted directory
FREIGHTER_EXTENSION_PATH=./freighter-extension

# Freighter unlock password (shared across all test profiles)
FREIGHTER_PASSWORD=What-a-useless-req

# Master secret — all test user keys are derived from this single secret.
# Default: local-dev hardcoded secret (SAQCGLJ2JISI67QGG457IBN2DY6YW5GGS2OMQU5KNLXB3TWVUIR2RD74).
# Override for testnet/mainnet with a funded Stellar secret key.
# MASTER_SECRET=S...

# ─── Local stack ports (match infra-up.sh defaults) ──────────────
# Only needed if you changed the defaults in up.sh.
# PROVIDER_PORT=3010
# COUNCIL_PLATFORM_PORT=3015
# PAY_PLATFORM_PORT=3025
# PROVIDER_CONSOLE_PORT=3020
# COUNCIL_CONSOLE_PORT=3030
# MOONLIGHT_PAY_PORT=3050
# STELLAR_RPC_PORT=8000

# ─── Testnet/mainnet OTEL (not needed for local — uses Jaeger) ───
# TEMPO_URL=https://tempo-prod-13-prod-ca-east-0.grafana.net/tempo
# TEMPO_AUTH=Basic MTUxMzA1MTp...

# OTEL service names (defaults match infra-up.sh)
# PROVIDER_SERVICE_NAME=provider-platform
# COUNCIL_SERVICE_NAME=council-platform
# PAY_SERVICE_NAME=pay-platform
