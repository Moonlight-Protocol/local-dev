FROM rust:1.89-bookworm

# Install wasm target for contract builds
RUN rustup target add wasm32v1-none

# Install system dependencies for stellar-cli
RUN apt-get update && apt-get install -y pkg-config libdbus-1-dev libudev-dev && rm -rf /var/lib/apt/lists/*

# Install Stellar CLI
RUN cargo install --locked stellar-cli

# Verify installation
RUN stellar version

WORKDIR /workspace

ENTRYPOINT ["/bin/bash"]
